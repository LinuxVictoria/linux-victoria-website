  <script>
    (function () {
      var eventStart = new Date('2026-08-25T00:00:00+10:00');
      var btn = document.getElementById('lrsOnlineRegister');
      var label = document.getElementById('lrsOnlineRegisterText');
      if (btn && new Date() >= eventStart) {
        btn.classList.remove('disabled');
        btn.removeAttribute('aria-disabled');
        btn.removeAttribute('tabindex');
        btn.setAttribute('target', '_blank');
        btn.setAttribute('rel', 'noopener');
        if (label) label.textContent = 'Register for Online Access';
      }
    })();
