  <style>
    :root {
      --lrs-indigo: #4E45CA;
      --lrs-purple: #803D99;
      --lrs-gradient: linear-gradient(135deg, var(--lrs-indigo) 0%, var(--lrs-purple) 100%);
    }

    @font-face {
      font-family: "Ubuntu";
      src: url("/assets/fonts/UbuntuSans-VariableFont_wdth,wght.ttf") format("truetype");
      font-weight: 100 900;
      font-style: normal;
    }

    body {
      font-family: "Ubuntu", var(--bs-body-font-family);
      background: #fff;
    }

    .bg-primary { background-color: var(--lrs-purple) !important; }
    .text-primary { color: var(--lrs-purple) !important; }
    .border-primary { border-color: var(--lrs-purple) !important; }

    .btn-primary {
      background-color: var(--lrs-purple);
      border-color: var(--lrs-purple);
    }

    .btn-primary:hover {
      background-color: var(--lrs-indigo);
      border-color: var(--lrs-indigo);
    }

    .bg-primary-subtle {
      background-color: rgba(128, 61, 153, 0.08) !important;
    }

    /* ---------- Hero ---------- */
    .lrs-hero {
      position: relative;
      overflow: hidden;
      background: var(--lrs-gradient);
      background-size: 220% 220%;
      animation: lrs-aurora 16s ease-in-out infinite;
      color: #fff;
      padding: 6rem 1rem;
      margin-bottom: 3.5rem;
    }

    .lrs-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 35%, rgba(255,255,255,0.16) 0%, rgba(255,255,255,0) 60%);
      pointer-events: none;
    }

    @keyframes lrs-aurora {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }

    .lrs-hero .shard {
      position: absolute;
      width: 140%;
      max-width: none;
      opacity: 0.28;
      mix-blend-mode: overlay;
      pointer-events: none;
      user-select: none;
    }

    .lrs-hero .shard-a {
      top: -20%;
      left: -25%;
      transform: rotate(8deg);
      animation: lrs-drift-a 26s ease-in-out infinite;
    }

    .lrs-hero .shard-b {
      bottom: -35%;
      right: -30%;
      transform: rotate(-14deg) scaleX(-1);
      animation: lrs-drift-b 32s ease-in-out infinite;
    }

    @keyframes lrs-drift-a {
      0%, 100% { transform: rotate(8deg) translate(0, 0); }
      50% { transform: rotate(11deg) translate(2%, 3%); }
    }

    @keyframes lrs-drift-b {
      0%, 100% { transform: rotate(-14deg) scaleX(-1) translate(0, 0); }
      50% { transform: rotate(-17deg) scaleX(-1) translate(-2%, -2%); }
    }

    .lrs-hero-content {
      position: relative;
      z-index: 2;
    }

    .lrs-title-row {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      margin-bottom: 1.25rem;
    }

    .lrs-hero h1 {
      font-size: clamp(1.75rem, 4vw, 2.75rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 0;
      text-shadow: 0 4px 30px rgba(0,0,0,0.25);
    }

    .lrs-year-badge {
      width: 110px;
      height: auto;
      flex-shrink: 0;
      filter: drop-shadow(0 6px 14px rgba(0,0,0,0.25));
    }

    @media (min-width: 768px) {
      .lrs-year-badge {
        width: 130px;
      }
    }

    .lrs-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,0.35);
      padding: 0.5rem 1.25rem;
      border-radius: 999px;
      font-weight: 600;
      animation: lrs-pulse 3s ease-in-out infinite;
    }

    @keyframes lrs-pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.04); }
    }

    .lrs-tbc-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,0.4);
      color: #fff;
      font-weight: 700;
      padding: 0.35rem 0.9rem;
      border-radius: 999px;
      font-size: 0.85rem;
      letter-spacing: 0.02em;
    }

    .lrs-hero-cta {
      background: #fff;
      color: var(--lrs-purple);
      font-weight: 700;
      border: none;
      box-shadow: 0 10px 30px rgba(0,0,0,0.25);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .lrs-hero-cta:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(0,0,0,0.3);
      color: var(--lrs-indigo);
    }

    @media (prefers-reduced-motion: reduce) {
      .lrs-hero, .lrs-hero .shard, .lrs-badge {
        animation: none !important;
      }
    }

    /* ---------- Cards ---------- */
    .theme-item:hover {
      transform: translateY(-2px);
      transition: all 0.3s ease;
    }

    .lrs-coming-soon {
      border: 2px dashed rgba(128, 61, 153, 0.35);
      border-radius: 1rem;
      background: rgba(128, 61, 153, 0.03);
    }

    .sponsor-cta {
      background: var(--lrs-gradient);
      color: #fff;
      border-radius: 1rem;
    }

    .sponsor-cta .btn-light {
      font-weight: 700;
      color: var(--lrs-purple);
    }
  </style>
</head>

