# .env.example — Linux Victoria Website
#
# Copy this file to .env for local development (never commit .env).
# All variables marked "Netlify" must be set in the Netlify dashboard under
#   Site configuration → Environment variables.
# All variables marked "GitHub" must be set as repository secrets under
#   GitHub → Settings → Secrets and variables → Actions.

# ─────────────────────────────────────────────────────────────────────────────
# Telegram — shared bot token
# Used by both the GitHub Actions workflow (pr_notify.yml) and the Netlify
# form-notify function. Create a bot via @BotFather and paste the token here.
# ─────────────────────────────────────────────────────────────────────────────

# [GitHub secret] [Netlify env var]
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Telegram — GitHub Actions (PR / Issue / Deploy notifications)
# pr_notify.yml routes these events to this chat/topic.
# ─────────────────────────────────────────────────────────────────────────────

# [GitHub secret] Chat or group ID to send PR/issue/deploy notifications to.
TELEGRAM_CHAT_ID=

# [GitHub secret] Topic (thread) ID within the group. Omit if the group has no topics.
TELEGRAM_THREAD_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Telegram — Netlify Forms (form-notify function)
# Triggered by the Netlify webhook:
#   Site config → Forms → Form notifications → HTTP POST request
#   → /.netlify/functions/form-notify
#
# Covers the native Netlify forms on this site:
#   • "contact"     (src/contact.md)
#   • "submissions" (src/submissions.md)
# ─────────────────────────────────────────────────────────────────────────────

# [Netlify env var] Chat or group ID to send form submission notifications to.
TELEGRAM_FORMS_CHAT_ID=

# [Netlify env var] Topic (thread) ID within the group. Omit if the group has no topics.
TELEGRAM_FORMS_THREAD_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: per-form overrides (route a specific form to a different chat/topic)
# The function checks for these before falling back to the globals above.
# FORM_NAME is the uppercased form name with non-alphanumeric chars replaced by _.
# Example for the "contact" form:
# ─────────────────────────────────────────────────────────────────────────────

# TELEGRAM_FORMS_CONTACT_CHAT_ID=
# TELEGRAM_FORMS_CONTACT_THREAD_ID=
# TELEGRAM_FORMS_SUBMISSIONS_CHAT_ID=
# TELEGRAM_FORMS_SUBMISSIONS_THREAD_ID=
